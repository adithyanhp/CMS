@page "/Attendance/attendentrylist"
@page "/Attendance/attendentrylist/{FrmId:int}"
@using BCA007.Shared.Service.Attendance
@inject ISnackbar _snackbar
@inject IAttendEntryService _serv
@inject IDialogService _dialog

<MudPaper Class="pa-0 mt-6">
    <MudDataGrid Dense Hover Items="_list" Loading="_loading"
                 QuickFilter="QuickFilter"
                 SortMode="SortMode.Multiple"
                 @ref="_grid">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Attendance Entry Form</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start" Immediate="true"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            <MudButtonGroup Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled">
                @* <MudButton StartIcon="@Icons.Material.Filled.Add"
                           Color="Color.Primary" Size="Size.Small"
                           OnClick="CreateDetails">
                    Add
                </MudButton> *@
                <MudButton StartIcon="@Icons.Material.Filled.Refresh"
                           Color="Color.Primary" Size="Size.Small"
                           OnClick="OnRefresh">
                    Refresh
                </MudButton>
               @*  <MudButton StartIcon="@Icons.Material.Filled.Help"
                           Color="Color.Primary" Size="Size.Small"
                           OnClick="OnRefresh">
                    Help
                </MudButton> *@
            </MudButtonGroup>
        </ToolBarContent>

        <Columns>
@*             <PropertyColumn Property="x => x.Att_Form_Id" Title="Id" /> *@
            <PropertyColumn Property="x => x.Date" Title="Date" />
            <PropertyColumn Property="x => x.UserName" Title="Student Name" />
            <PropertyColumn Property="x => x.Class_Name" Title="Class Name" />
            <PropertyColumn Property="x => x.Att_1" Title="Status" />
            <PropertyColumn Property="x => x.Att_2" Title="Status" />
            <PropertyColumn Property="x => x.Att_3" Title="Status" />
            <PropertyColumn Property="x => x.Att_4" Title="Status" />
            <PropertyColumn Property="x => x.Att_5" Title="Status" />
            @* <PropertyColumn Property="x => x.Form_1" Title="Status" />
            <PropertyColumn Property="x => x.Form_2" Title="Status" />
            <PropertyColumn Property="x => x.Form_3" Title="Status" />
            <PropertyColumn Property="x => x.Form_4" Title="Status" />
            <PropertyColumn Property="x => x.Form_5" Title="Status" /> *@



            <TemplateColumn Title="Actions">
                <CellTemplate Context="row">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => EditDetails(row.Item))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => DeleteDetails(row.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager PageSizeOptions="new int[] { 5, 10, 25, 100 }" />
        </PagerContent>
    </MudDataGrid>

</MudPaper>

