    private async Task OnRefresh()
    {
        try
        {
            _loading = true;

            if (FrmId.HasValue && FrmId.Value > 0)
                _list = await _serv.GetAttendanceById(FrmId);
            else
                _list = await _serv.GetAllAsync();

            if (_list == null || !_list.Any())
                _snackbar.Add("No attendance found.", Severity.Warning);
        }
        catch (Exception ex)
        {
            _snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }


    private async Task CreateDetails()
    {
        await OpenDetailsDialog(new AttendEntryDto(), "Create");
    }

    private async Task EditDetails(AttendEntryViewDto dto)
    {
        // IMPORTANT: pass a COPY
        await OpenDetailsDialog(new AttendEntryDto
        {
             Id = dto.Id,
             Att_Form_Id = dto.Att_Form_Id,
            Period1_Att_Id = dto.Period1_Att_Id,
            Period2_Att_Id = dto.Period2_Att_Id,
            Period3_Att_Id = dto.Period3_Att_Id,
            Period4_Att_Id = dto.Period4_Att_Id,
            Period5_Att_Id = dto.Period5_Att_Id,
            Student_Id = dto.Student_Id,
        
           
        }, "Edit");
    }
    private async Task DeleteDetails(AttendEntryViewDto dto)
    {
        await OpenDetailsDialog(new AttendEntryDto
        {
             Id = dto.Id,
             Att_Form_Id = dto.Att_Form_Id,
            Period1_Att_Id = dto.Period1_Att_Id,
            Period2_Att_Id = dto.Period2_Att_Id,
            Period3_Att_Id = dto.Period3_Att_Id,
            Period4_Att_Id = dto.Period4_Att_Id,
            Period5_Att_Id = dto.Period5_Att_Id,
            Student_Id = dto.Student_Id,
            //Date = dto.Date,
            

        }, "Delete");
    }
    private async Task OpenDetailsDialog(AttendEntryDto model, string action)
    {
        _loading = true;
        var parameters = new DialogParameters
        {
            ["Model"] = model,
            ["Action"] = action
        };
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            BackdropClick = false
        };

        var dialog = await _dialog.ShowAsync<AttendEntryEdit>(
           $"{action} Attendance",
            parameters, options);

        var result = await dialog.Result;
        _loading = false;

        if (result == null)
            return;
        if (result.Canceled)
            return;
        if (result.Data == null)
            return;

        await OnRefresh();
        await InvokeAsync(StateHasChanged);
    }

